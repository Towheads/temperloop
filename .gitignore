.DS_Store
/Makefile.local
# Host-local funnel/build override + secrets (#709): sourced by build.config.sh
# if present, gitignored so credentials (e.g. SENTRY_* for /signal-intake) never
# commit. Template: workflows/scripts/build/build.config.local.sh.example.
/workflows/scripts/build/build.config.local.sh
# Operator-personal leak-guard denylist overlay (temperloop#438): the tracked
# personal-token-denylist.tsv ships only structural/example rows; the real
# operator/personal deny patterns (name, personal emails, machine names,
# Sentry slug, vault path) live in this untracked overlay, which the leak-guard
# reads when present and degrades legibly when absent. Never committed.
/workflows/scripts/kernel/personal-token-denylist.local.tsv
.mind/
.claude/settings.local.json
.claude/*.lock
# Project-scoped review-agent / command deploy (temperloop#290): the live
# .claude/agents/ + .claude/commands/ that
# workflows/scripts/install/project-agents.sh generates (symlinks or copies)
# from the tracked claude/agents/ + claude/commands/ sources so Claude Code's
# capability probe resolves them. Never committed — regenerated by that
# install step in any fresh clone; the tracked source under claude/ is the
# single source of truth.
.claude/agents/
.claude/commands/
meta/data/*
# The raw-lake sink-spec stub (kernel #29) IS committed — it's the doc the
# emit-site headers point at, not a generated/host-local artifact — while
# every actual raw-lake data file (command-runs-*.jsonl, issue-touches-*.jsonl,
# claims-*.jsonl, funnel-*.jsonl) under meta/data/raw/ stays gitignored, same
# nested-negation shape as the docs/_site/.gitkeep precedent below.
!meta/data/raw/
meta/data/raw/*
!meta/data/raw/README.md
dashboard/index.html
# Docs-site generator output (F#764): never committed, mirrors the
# dashboard/index.html precedent above. .gitkeep tracked so the dir exists
# in a fresh clone; everything else under _site/ is regenerated by `make
# docs` (workflows/scripts/docs/generate.py).
workflows/scripts/docs/_site/*
!workflows/scripts/docs/_site/.gitkeep
mind_snapshot/
__pycache__/
# Build-spine dev-local artifacts (#529): the per-item verification surface a
# /build worker writes, and the write-jail marker. Never committed — the spine
# keeps them out via .git/info/exclude (worktree.sh exclude_marker); listing them
# here is the committed, self-documenting belt for non-build clones.
.build-verification.md
.build-guard
# Reviewer activation opt-in state (temperloop#549): the durable-decline
# marker directory workflows/scripts/install/reviewer-activate.sh writes to
# and reviewer-activation-coverage.sh (#548) / a future `make doctor` check
# (#550) read from. Per-repo install/local state — never committed.
.claude/reviewer-state/
# Pinned-tool download cache (temperloop#567): scripts/ensure-shellcheck.sh
# caches the pinned shellcheck static binary here. Host-local, regenerated on
# demand — never committed.
.cache/
