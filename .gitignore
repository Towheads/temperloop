.DS_Store
/Makefile.local
# Host-local funnel/build override + secrets (#709): sourced by build.config.sh
# if present, gitignored so credentials (e.g. SENTRY_* for /signal-intake) never
# commit. Template: workflows/scripts/build/build.config.local.sh.example.
/workflows/scripts/build/build.config.local.sh
.mind/
.claude/settings.local.json
.claude/*.lock
meta/data/
dashboard/index.html
# Docs-site generator output (F#764): never committed, mirrors the
# dashboard/index.html precedent above. .gitkeep tracked so the dir exists
# in a fresh clone; everything else under _site/ is regenerated by `make
# docs` (workflows/scripts/docs/generate.py).
workflows/scripts/docs/_site/*
!workflows/scripts/docs/_site/.gitkeep
mind_snapshot/
__pycache__/
# Build-spine dev-local artifacts (#529): the per-item verification surface a
# /build worker writes, and the write-jail marker. Never committed — the spine
# keeps them out via .git/info/exclude (worktree.sh exclude_marker); listing them
# here is the committed, self-documenting belt for non-build clones.
.build-verification.md
.build-guard
