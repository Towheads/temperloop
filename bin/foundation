#!/usr/bin/env bash
# foundation — DEPRECATED compat shim (foundation #893). The CLI's public
# name is TemperLoop (binary `temperloop`, see kernel/bin/temperloop and
# Decisions/foundation - Kernel public name TemperLoop); this file exists
# only so an existing `foundation <sub>` caller — a script, a shell alias,
# an already-bootstrapped install — keeps working unchanged. It does
# nothing but resolve its own location (following symlinks, so an
# already-installed `~/.local/bin/foundation` symlink still works) and exec
# the real dispatcher next to it. New callers should use `temperloop`.
set -uo pipefail

_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  case "$_src" in /*) ;; *) _src="$_dir/$_src" ;; esac
done
_bin_dir="$(cd -P "$(dirname "$_src")" && pwd)"
unset _src _dir

exec "$_bin_dir/temperloop" "$@"
