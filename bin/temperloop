#!/usr/bin/env bash
#
# temperloop — the kernel's newcomer/adoption-surface CLI entrypoint
# (foundation #765 Epic D "newcomer experience", item cli-entrypoint-
# bootstrap / #849). Public name TemperLoop; this binary was renamed from
# `foundation` (foundation #893) — `kernel/bin/foundation` remains a thin
# compat shim that execs this file so an existing `foundation <sub>` caller
# keeps working. See Decisions/foundation - Kernel public name TemperLoop.
#
# SCOPE (read before adding a subcommand): this CLI is the surface a
# STRANGER meets before they have a working checkout — install, look around
# read-only, try a demo, opt in, eject. It is NOT a second front door onto
# an existing checkout's day-to-day work: every in-checkout operation (the
# board toolkit, the build/sweep pipeline, the quality gates) stays on
# `make` — see the repo's Makefile. Do not grow this dispatcher into a
# shadow copy of Makefile targets; if a subcommand's job is "wrap an
# existing make target", it belongs in the Makefile instead, not here.
#
# DISPATCH MODEL (load-bearing — read before adding a subcommand file):
#   Subcommands are DISCOVERED FILES, never a hand-edited case statement:
#   any kernel/bin/subcommands/<name>.sh file IS `temperloop <name>`,
#   automatically, the moment the file exists. This is what lets
#   independent items (foundation-try, foundation-init, foundation-eject,
#   ...) land their own subcommand file in parallel with zero coordination
#   and zero merge conflict in this dispatcher — see the epic's plan note,
#   "## Sequencing notes".
#
#   Each subcommand is EXECUTED IN ITS OWN PROCESS (`bash "$file" "$@"`),
#   never `source`d into this script's shell — so a subcommand can set its
#   own `set -e`, define its own functions/variables, and `exit` on its own
#   terms without ever touching this dispatcher's namespace or accidentally
#   terminating it. A subcommand file sourcing kernel/bin/lib/*.sh for
#   shared helpers/constants INSIDE ITS OWN process is a normal library
#   import, not a violation of this rule — the rule is about how THIS
#   dispatcher invokes a subcommand, not what a subcommand does internally.
#
#   Built-in verbs (help/-h/--help, version/-v/--version) are NOT discovered
#   files — they are the fixed CLI framework surface, exactly like `git
#   help` / `git --version` sit outside git's own plugin (`git-<verb>`)
#   mechanism. A new FEATURE belongs in subcommands/, never as a new verb
#   handled here.
#
# Every subcommand dispatch (anything past help/version) runs a prereq
# check first — Claude Code CLI on PATH + gh authenticated — with an honest,
# specific failure message per missing piece (see lib/common.sh). This is
# centralized here so no individual subcommand item has to reimplement it.
#
# Alongside that prereq check sits a second, PASSIVE pre-dispatch check: the
# 14-day report auto-offer (foundation #766 Epic E, item report-auto-offer /
# #880). See _foundation_check_report_offer below for the full contract.
set -uo pipefail

# --- resolve this script's real location, following symlinks. Portable
# (no GNU readlink -f) — the exact idiom already used by
# workflows/scripts/board/claim.sh et al., so a `temperloop` invoked through
# the curl-bootstrap's ~/.local/bin/temperloop symlink (or a `foundation`
# compat-shim symlink) still finds its real sibling subcommands/ and lib/
# directories. ---
_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  case "$_src" in /*) ;; *) _src="$_dir/$_src" ;; esac
done
FOUNDATION_BIN_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
unset _src _dir

SUBCOMMANDS_DIR="$FOUNDATION_BIN_DIR/subcommands"
LIB_DIR="$FOUNDATION_BIN_DIR/lib"

# shellcheck source=lib/common.sh
source "$LIB_DIR/common.sh"

FOUNDATION_VERSION="${FOUNDATION_VERSION:-dev}"

# _foundation_subcommand_description <file>
#   Prints the file's `# description: ...` header line — a documented,
#   lightweight convention every subcommand file follows (see
#   kernel/workflows/scripts/docs/sources/cli.py, which renders the same
#   convention into the docs site's subcommand-reference table) — or a
#   placeholder if the file doesn't have one.
_foundation_subcommand_description() {
  local file="$1" line
  line="$(grep -m1 '^# description: ' "$file" 2>/dev/null || true)"
  if [[ -n "$line" ]]; then
    printf '%s\n' "${line#\# description: }"
  else
    printf '%s\n' "(no description)"
  fi
}

_foundation_print_help() {
  cat <<EOF
temperloop — kernel newcomer/adoption-surface CLI

Usage:
  temperloop <subcommand> [args...]
  temperloop help
  temperloop --version

Subcommands:
EOF
  local found=0 file name
  for file in "$SUBCOMMANDS_DIR"/*.sh; do
    [[ -e "$file" ]] || continue
    found=1
    name="$(basename "$file" .sh)"
    printf '  %-16s %s\n' "$name" "$(_foundation_subcommand_description "$file")"
  done
  if [[ "$found" -eq 0 ]]; then
    echo "  (none installed yet)"
  fi
  cat <<EOF

In-checkout operations (board, build, quality gates) stay on 'make' — this
CLI is the pre-checkout newcomer surface only.

Running from: ${FOUNDATION_BIN_DIR%/bin}
Default install location: $FOUNDATION_CLI_HOME_DEFAULT
  (symlinked onto PATH at $FOUNDATION_CLI_BIN_DEFAULT by bin/bootstrap.sh)
EOF
}

# _foundation_check_report_offer <cmd>
#   The 14-day report auto-offer (foundation #766 Epic E "cost/benefit value
#   loop", item report-auto-offer / #880): a PASSIVE, pre-dispatch nudge —
#   no cron, no daemon, no new verb — that prints a one-line offer to run
#   `foundation report` once the target repo's baseline snapshot
#   (.foundation/baseline.jsonl, written by `foundation baseline-snapshot` —
#   see kernel/workflows/scripts/lib/baseline_snapshot.contract.md) is at
#   least 14 days old and the offer hasn't already fired for this repo.
#
#   ANCHOR: the FIRST record's embedded `generated_at` (never the file's OS
#   mtime, which a clone/checkout/restore can silently reset with no
#   relationship to when the baseline was actually captured — same
#   reasoning as the contract doc's own note on this field). The first
#   record is used, not the latest, because it's the fixed "before" instant
#   the whole value loop measures from.
#
#   FIRES ONCE: the moment this prints, it durably marks itself dismissed
#   (keyed by repo) under ${XDG_STATE_HOME:-$HOME/.local/state}/foundation/
#   — never inside the repo tree itself, since a committed dismissal would
#   silently dismiss the offer for every collaborator who clones the repo.
#   That state file's mere existence IS "dismissed"; there is no separate
#   dismiss verb or flag to maintain.
#
#   LATE-FIRE CAVEAT (accepted, not worked around): this only runs when the
#   user happens to invoke `foundation <subcommand>` again after the
#   14-day mark. Day-to-day work in an adopted checkout mostly stays on
#   `make` (see this dispatcher's own scope note above), so post-init
#   invocations of this CLI may be rare — a checkout that goes quiet after
#   `init` may see the offer fire late, or not at all in a given session.
#   A cron/daemon would close that gap but is explicitly out of scope (see
#   the item's acceptance criteria); this is a zero-infrastructure nudge,
#   not a scheduler.
#
#   SOFT SEAM: any missing piece (no baseline file, no jq on PATH, an
#   unparseable first record, no resolvable repo root) degrades to a
#   silent no-op — this is advisory noise, never a gate, and never blocks
#   or fails the subcommand dispatch that follows it.
_foundation_check_report_offer() {
  local cmd="$1"
  local repo_root baseline_file first_record generated_at
  local now_epoch gen_epoch age_days dismiss_key dismiss_dir dismiss_file

  command -v jq >/dev/null 2>&1 || return 0

  repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || repo_root="$(pwd)"
  baseline_file="$repo_root/.foundation/baseline.jsonl"
  [ -f "$baseline_file" ] || return 0

  first_record="$(head -n1 "$baseline_file" 2>/dev/null)"
  [ -n "$first_record" ] || return 0

  generated_at="$(printf '%s' "$first_record" | jq -r '.generated_at // empty' 2>/dev/null)"
  [ -n "$generated_at" ] || return 0

  gen_epoch="$(jq -n --arg ts "$generated_at" 'try ($ts | fromdateiso8601) catch empty' 2>/dev/null)"
  case "$gen_epoch" in ''|*[!0-9]*) return 0 ;; esac

  now_epoch="$(date -u +%s)"
  age_days=$(( (now_epoch - gen_epoch) / 86400 ))
  [ "$age_days" -ge 14 ] || return 0

  dismiss_key="${repo_root//\//_}"
  dismiss_dir="${XDG_STATE_HOME:-$HOME/.local/state}/foundation/report-offer-dismissed"
  dismiss_file="$dismiss_dir/$dismiss_key"
  [ -f "$dismiss_file" ] && return 0

  echo "temperloop: your baseline snapshot is ${age_days} days old — run 'foundation baseline-snapshot && foundation report' to see your before/after value (won't ask again for this repo)." >&2

  mkdir -p "$dismiss_dir" 2>/dev/null && : > "$dismiss_file" 2>/dev/null
  return 0
}

cmd="${1:-help}"

if [[ "$cmd" == "help" || "$cmd" == "-h" || "$cmd" == "--help" ]]; then
  _foundation_print_help
  exit 0
fi

if [[ "$cmd" == "--version" || "$cmd" == "-v" || "$cmd" == "version" ]]; then
  echo "temperloop $FOUNDATION_VERSION"
  exit 0
fi

subcommand_file="$SUBCOMMANDS_DIR/$cmd.sh"
if [[ ! -f "$subcommand_file" ]]; then
  echo "temperloop: unknown subcommand '$cmd'" >&2
  echo "Run 'temperloop help' to list installed subcommands." >&2
  exit 1
fi

if ! foundation_check_prereqs; then
  echo "" >&2
  echo "temperloop: fix the above, then re-run: temperloop $cmd" >&2
  exit 1
fi

_foundation_check_report_offer "$cmd"

shift
bash "$subcommand_file" "$@"
exit $?
